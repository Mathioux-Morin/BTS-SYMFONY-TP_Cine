{
  "id": "test-authentication",
  "version": "2.0",
  "name": "Test Authentication",
  "url": "http://localhost",
  "tests": [
    {
      "id": "test-access-login-page",
      "name": "Access Login Page",
      "commands": [
        {
          "command": "open",
          "target": "http://localhost/login",
          "value": ""
        },
        {
          "command": "waitForElementVisible",
          "target": "css=form[method='POST'], .login-form",
          "value": "5000"
        },
        {
          "command": "verifyElementPresent",
          "target": "css=input[name='_username'], input[name='username']",
          "value": ""
        },
        {
          "command": "verifyElementPresent",
          "target": "css=input[name='_password'], input[name='password']",
          "value": ""
        }
      ]
    },
    {
      "id": "test-login-invalid-credentials",
      "name": "Login with Invalid Credentials",
      "commands": [
        {
          "command": "open",
          "target": "http://localhost/login",
          "value": ""
        },
        {
          "command": "type",
          "target": "css=input[name='_username']",
          "value": "invaliduser@example.com"
        },
        {
          "command": "type",
          "target": "css=input[name='_password']",
          "value": "invalidpassword"
        },
        {
          "command": "click",
          "target": "css=button[type='submit']",
          "value": ""
        },
        {
          "command": "waitForElementVisible",
          "target": "css=.alert.alert-danger, [role='alert']",
          "value": "5000"
        }
      ]
    },
    {
      "id": "test-login-valid-credentials",
      "name": "Login with Valid Credentials",
      "commands": [
        {
          "command": "open",
          "target": "http://localhost/login",
          "value": ""
        },
        {
          "command": "type",
          "target": "css=input[name='_username']",
          "value": "user@example.com"
        },
        {
          "command": "type",
          "target": "css=input[name='_password']",
          "value": "password123"
        },
        {
          "command": "click",
          "target": "css=button[type='submit']",
          "value": ""
        },
        {
          "command": "waitForElementVisible",
          "target": "css=body",
          "value": "5000"
        },
        {
          "command": "verifyElementNotPresent",
          "target": "css=.alert.alert-danger",
          "value": ""
        }
      ]
    },
    {
      "id": "test-logout",
      "name": "Logout",
      "commands": [
        {
          "command": "open",
          "target": "http://localhost/",
          "value": ""
        },
        {
          "command": "click",
          "target": "xpath=//a[contains(text(), 'Logout')] | //a[contains(@href, '/logout')]",
          "value": ""
        },
        {
          "command": "waitForElementVisible",
          "target": "css=body",
          "value": "5000"
        }
      ]
    }
  ],
  "suites": [
    {
      "id": "authentication-suite",
      "name": "Authentication Suite",
      "parallel": false,
      "persistSession": false,
      "timeout": 300,
      "tests": [
        "test-access-login-page",
        "test-login-invalid-credentials",
        "test-login-valid-credentials",
        "test-logout"
      ]
    }
  ],
  "urls": [
    "http://localhost/"
  ],
  "plugins": []
}
