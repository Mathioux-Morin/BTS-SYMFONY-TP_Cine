<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card bg-secondary border-0 shadow-lg">
                <div class="card-body p-5">
                    {{ form_start(form, {'attr': {'class': 'needs-validation'}}) }}
                        <div class="mb-4">
                            {{ form_label(form.title, 'Titre du film', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                            {{ form_widget(form.title, {'attr': {'class': 'form-control form-control-lg'}}) }}
                            {{ form_errors(form.title) }}
                        </div>

                        <div class="mb-4">
                            {{ form_label(form.overview, 'Synopsis', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                            {{ form_widget(form.overview, {'attr': {'class': 'form-control form-control-lg', 'rows': '5'}}) }}
                            {{ form_errors(form.overview) }}
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-4">
                                {{ form_label(form.releaseDate, 'Date de sortie', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                                {{ form_widget(form.releaseDate, {'attr': {'class': 'form-control form-control-lg'}}) }}
                                {{ form_errors(form.releaseDate) }}
                            </div>

                            <div class="col-md-6 mb-4">
                                {{ form_label(form.runtime, 'Durée', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                                {{ form_widget(form.runtime, {'attr': {'class': 'form-control form-control-lg', 'placeholder': 'ex: 120 min'}}) }}
                                {{ form_errors(form.runtime) }}
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-4">
                                {{ form_label(form.posterPath, 'URL de l\'affiche', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                                {{ form_widget(form.posterPath, {'attr': {'class': 'form-control form-control-lg'}}) }}
                                {{ form_errors(form.posterPath) }}
                            </div>

                            <div class="col-md-6 mb-4">
                                {{ form_label(form.idIMDB, 'ID IMDB', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                                {{ form_widget(form.idIMDB, {'attr': {'class': 'form-control form-control-lg', 'placeholder': 'ex: tt0068646'}}) }}
                                {{ form_errors(form.idIMDB) }}
                            </div>
                        </div>

                        <div class="d-flex gap-2 justify-content-between mt-5">
                            <button type="submit" class="btn btn-primary btn-lg px-5">
                                <i class="bi bi-check-circle me-2"></i>{{ button_label|default('Enregistrer') }}
                            </button>
                            <a href="{{ path('app_movie_crud_index') }}" class="btn btn-outline-light btn-lg px-5">
                                <i class="bi bi-arrow-left me-2"></i>Annuler
                            </a>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
