<form method="post" action="{{ path('app_movie_crud_delete', {'id': movie.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce film ?');" class="d-inline">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ movie.id) }}">
    <button class="btn btn-danger btn-lg px-5">
        <i class="bi bi-trash me-2"></i>Supprimer ce film
    </button>
</form>
