{% extends 'base.html.twig' %}

{% block title %}Éditer la collection{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row mb-5">
        <div class="col-12">
            <h1 class="display-4 fw-bold mb-2">Éditer la collection</h1>
            <p class="text-muted fs-5">{{ collection.name }}</p>
        </div>
    </div>

    {{ include('collections/_form.html.twig', {'button_label': 'Mettre à jour', 'tmdb_image_prefix': tmdb_image_prefix}) }}

    <div class="container mt-5 mb-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="d-flex justify-content-center pt-5 border-top border-secondary">
                    {{ include('collections/_delete_form.html.twig') }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
