{% extends 'base.html.twig' %}

{% block title %}Mes collections{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row mb-5">
        <div class="col-md-6">
            <h1 class="display-4 fw-bold mb-2">Mes Collections</h1>
            <p class="text-muted fs-5">Organisez vos films préférés en collections</p>
        </div>
        <div class="col-md-6 d-flex align-items-center justify-content-md-end">
            <a href="{{ path('app_collections_new') }}" class="btn btn-primary btn-lg px-5">
                <i class="bi bi-plus-circle me-2"></i>Créer une collection
            </a>
        </div>
    </div>

    {% if collections %}
        <div class="row g-4">
            {% for collection in collections %}
                <div class="col-md-6 col-lg-4">
                    <a href="{{ path('app_collections_show', {'id': collection.id}) }}" class="text-decoration-none">
                        <div class="card bg-secondary border-0 h-100 shadow-sm transition-all" style="transition: all 0.3s ease;">
                            <div class="card-body d-flex flex-column">
                                <h5 class="card-title text-light fw-bold fs-5 mb-3">{{ collection.name }}</h5>

                                <div class="mb-3 flex-grow-1">
                                    {% if collection.movies %}
                                        <div class="d-flex align-items-center gap-2 mb-2">
                                            <i class="bi bi-film text-primary"></i>
                                            <span class="text-muted">{{ collection.movies|length }} film{{ collection.movies|length > 1 ? 's' : '' }}</span>
                                        </div>
                                        <small class="text-light">
                                            {% for movie in collection.movies|slice(0, 2) %}
                                                <span class="badge bg-primary me-1">{{ movie.title|slice(0, 15) }}{{ movie.title|length > 15 ? '...' : '' }}</span>
                                            {% endfor %}
                                            {% if collection.movies|length > 2 %}
                                                <span class="badge bg-secondary">+{{ collection.movies|length - 2 }}</span>
                                            {% endif %}
                                        </small>
                                    {% else %}
                                        <div class="text-muted fs-6">
                                            <i class="bi bi-inbox text-muted"></i> Aucun film
                                        </div>
                                    {% endif %}
                                </div>

                                <div class="d-flex gap-2 pt-3 border-top border-dark">
                                    <a href="{{ path('app_collections_edit', {'id': collection.id}) }}" class="btn btn-sm btn-outline-light flex-grow-1">
                                        <i class="bi bi-pencil me-1"></i>Éditer
                                    </a>
                                    <form method="post" action="{{ path('app_collections_delete', {'id': collection.id}) }}" style="flex-grow: 1;">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ collection.id) }}">
                                        <button type="submit" class="btn btn-sm btn-outline-danger w-100" onclick="return confirm('Êtes-vous sûr ?');">
                                            <i class="bi bi-trash me-1"></i>Supprimer
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="row justify-content-center mt-5">
            <div class="col-md-6 text-center">
                <div class="card bg-secondary border-0 shadow-sm py-5">
                    <div class="card-body">
                        <i class="bi bi-collection display-1 text-muted mb-3" style="display: block;"></i>
                        <h5 class="text-light fw-bold mb-3">Aucune collection</h5>
                        <p class="text-muted mb-4">Vous n'avez pas encore créé de collection. Commencez par en créer une !</p>
                        <a href="{{ path('app_collections_new', parameters={'idCreator': app.user.id}) }}" class="btn btn-primary px-5">
                            <i class="bi bi-plus-circle me-2"></i>Créer ma première collection
                        </a>
                    </div>
                </div>
            </div>
        </div>
    {% endif %}
</div>

<style>
    .transition-all:hover {
        transform: translateY(-5px);
        box-shadow: 0 0.5rem 1.5rem rgba(0, 0, 0, 0.3) !important;
    }
</style>
{% endblock %}
