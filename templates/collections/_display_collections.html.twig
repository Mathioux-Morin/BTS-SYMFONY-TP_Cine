<div class="d-flex flex-wrap justify-content-center">
    {% for collection in collections %}
        <a href="{{ path(name = 'collections_show', parameters = {'idMovie': movie.id}) }} " class="text-decoration-none text-light m-2">
            <div class="card bg-dark text-light m-2" style="width: 18rem;">
                {% if movie.poster_path %}
                    <img src="{{ tmdb_image_prefix }}{{ movie.poster_path }}" class="card-img-top" alt="{{ movie.title }}">
                {% else %}
                    <img src="https://placehold.co/1000x1500/EEE/31343C?font=montserrat&text=No+Image" class="card-img-top" alt="No Image Available">
                {% endif %}
                <div class="card-body">
                    <h5 class="card-title">{{ collection.name }}</h5>
                    <p class="card-text">{{ collection.creator|length > 100 ? collection.creator|slice(0, 100) ~ '...' : collection.creator }}</p>
                </div>
            </div>
        </a>
{% endfor %}
</div>