{% extends 'base.html.twig' %}

{% block title %}{{ collection.name }}{% endblock %}

{% block body %}
<div class="container py-5">
    {# Titre et infos de la collection #}
    <div class="row mb-5">
        <div class="col-md-8">
            <h1 class="display-4 fw-bold mb-3">{{ collection.name }}</h1>
            <div class="d-flex gap-4 align-items-center">
                <div>
                    <span class="badge bg-primary px-3 py-2 fs-6">
                        <i class="bi bi-film me-2"></i>{{ collection.movies|length }} film{{ collection.movies|length > 1 ? 's' : '' }}
                    </span>
                </div>
                <div>
                    <small class="text-muted">Collection #{{ collection.id }}</small>
                </div>
            </div>
        </div>
        <div class="col-md-4 d-flex align-items-center justify-content-md-end gap-2">
            <a href="{{ path('app_collections_edit', {'id': collection.id}) }}" class="btn btn-warning btn-lg">
                <i class="bi bi-pencil me-2"></i>Éditer
            </a>
            <a href="{{ path('app_collections_index') }}" class="btn btn-outline-light btn-lg">
                <i class="bi bi-arrow-left me-2"></i>Retour
            </a>
        </div>
    </div>

    {# Films de la collection #}
    {% if collection.movies %}
        <div class="mb-5">
            <h2 class="h3 fw-bold mb-4">Films dans cette collection</h2>
            <div class="d-flex flex-wrap justify-content-start gap-4">
                {% for movie in collection.movies %}
                    <div class="card bg-dark text-light border-0" style="width: 15rem; position: relative; overflow: hidden; border-radius: 12px;">
                        <a href="{{ path('movie_show', {'idMovie': movie.id}) }}" class="text-decoration-none text-light">
                            {% if movie.poster_path %}
                                <img src="{{ tmdb_image_prefix }}{{ movie.poster_path }}" class="card-img-top" alt="{{ movie.title }}" style="height: 250px; object-fit: cover;">
                            {% else %}
                                <img src="https://placehold.co/1000x1500/EEE/31343C?font=montserrat&text=No+Image" class="card-img-top" alt="No Image" style="height: 250px; object-fit: cover;">
                            {% endif %}
                            <div class="card-body p-3">
                                <h6 class="card-title fw-bold" style="min-height: 3rem; overflow: hidden;">{{ movie.title }}</h6>
                                <p class="card-text text-muted small" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                    {{ movie.overview ?: 'Aucun résumé disponible' }}
                                </p>
                            </div>
                        </a>
                    </div>
                {% endfor %}
            </div>
        </div>
    {% else %}
        <div class="row justify-content-center my-5">
            <div class="col-md-6 text-center">
                <div class="card bg-secondary border-0 shadow-sm py-5">
                    <div class="card-body">
                        <i class="bi bi-inbox display-1 text-muted mb-3"></i>
                        <h5 class="text-light fw-bold mb-3">Aucun film</h5>
                        <p class="text-muted mb-4">Cette collection ne contient pas encore de film.</p>
                        <a href="{{ path('app_collections_edit', {'id': collection.id}) }}" class="btn btn-primary px-4">
                            <i class="bi bi-plus-circle me-2"></i>Ajouter des films
                        </a>
                    </div>
                </div>
            </div>
        </div>
    {% endif %}

    {# Personnes qui ont enregistré cette collection (à venir) #}
    <div class="row my-5">
        <div class="col-12">
            <hr class="bg-secondary">
        </div>
    </div>

    {% if collection.movieLovers %}
        <div class="mb-5">
            <h2 class="h3 fw-bold mb-4">Enregistrée par {{ collection.movieLovers|length }} personne{{ collection.movieLovers|length > 1 ? 's' : '' }}</h2>
            <div class="d-flex flex-wrap gap-3">
                {% for lover in collection.movieLovers %}
                    <div class="badge bg-info px-3 py-2" style="font-size: 0.95rem;">
                        <i class="bi bi-person me-2"></i>{{ lover.id }}
                    </div>
                {% endfor %}
            </div>
        </div>
    {% else %}
        <div class="alert alert-info" role="alert">
            <i class="bi bi-info-circle me-2"></i>
            Aucune personne n'a encore enregistré cette collection.
        </div>
    {% endif %}
</div>

<style>
    .card {
        transition: all 0.3s ease;
    }

    .card:hover {
        transform: translateY(-8px);
        box-shadow: 0 0.5rem 1.5rem rgba(0, 0, 0, 0.3) !important;
    }
</style>
{% endblock %}
